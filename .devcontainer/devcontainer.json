// For format details, see https://aka.ms/devcontainer.json. For config options, see the README at:
// https://github.com/microsoft/vscode-dev-containers/tree/v0.238.0/containers/jupyter-datascience-notebooks
{
	"name": "bigdata-rstudio-jupyter",
	"image": "ghcr.io/lescai-teaching/bigdata-rstudio-gitpod:latest",
	// Forward Jupyter port locally, mark required
	"forwardPorts": [8888],
	"portsAttributes": {
		"8888": {
			"label": "RStudio"
		}
	},

	// Configure tool-specific properties.
	"customizations": {
		// Configure properties specific to VS Code.
		"vscode": {
			// Set *default* container specific settings.json values on container create.
			"settings": { 
				"python.defaultInterpreterPath": "/opt/conda/bin/python"
			},
			
			// Add the IDs of extensions you want installed when the container is created.
			"extensions": [
				"ms-python.python"
			]
		}
	},
	"postStartCommand": "bash -c 'R_PATH=\"PATH=$PATH\"; echo $R_PATH >> /home/rstudio/.Renviron; for var in CODESPACE_NAME CODESPACES GITHUB_TOKEN GITHUB_USER GITHUB_SERVER_URL GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN; do val=$(printenv $var); [ -n \"$val\" ] && echo \"$var=$val\" >> /home/rstudio/.Renviron; done; mkdir -p /home/rstudio/.jupyter; cat > /home/rstudio/.jupyter/jupyter_server_config.py <<\"PY\"\nimport os\nimport jupyter_rsession_proxy\nfrom urllib.parse import urlparse, urlunparse\n\ndef fix(response, request):\n    name=os.environ.get(\"CODESPACE_NAME\")\n    domain=os.environ.get(\"GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN\", \"app.github.dev\")\n    host=f\"{name}-8888.{domain}\" if name else request.host\n    for h,v in list(response.headers.get_all()):\n        if h.lower()==\"location\":\n            p=urlparse(v)\n            path=p.path if p.path.startswith(\"/rstudio\") else \"/rstudio\"+p.path\n            response.headers[h]=urlunparse((\"https\", host, path, \"\", p.query, p.fragment))\n\njupyter_rsession_proxy.rewrite_netloc = fix\nPY'"
}
